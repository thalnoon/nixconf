# ----------------------------
# General Colors
# ----------------------------
# Main background and text colors
custom_background_color {{colors.surface.default.hex}}
custom_text_color {{colors.on_surface.default.hex}}
background_color {{colors.background.default.hex}}
page_separator_color {{colors.surface.default.hex}}

# ----------------------------
# UI & Status Bar
# ----------------------------
# Status bar at the bottom
status_bar_color {{colors.on_primary_fixed.default.hex}}
status_bar_text_color {{colors.on_surface.default.hex}}

# General UI elements
ui_background_color {{colors.surface.default.hex}}
ui_text_color {{colors.on_surface.default.hex}}

# Selected UI elements
ui_selected_background_color {{colors.primary.default.hex}}
ui_selected_text_color {{colors.on_primary.default.hex}}

# ----------------------------
# Highlights & Marks
# ----------------------------
# Search highlight
search_highlight_color {{colors.tertiary_container.default.hex}}

# Text highlight
text_highlight_color {{colors.primary_container.default.hex}}

# Link highlight
link_highlight_color {{colors.secondary.default.hex}}

# Synctex highlight
synctex_highlight_color {{colors.secondary_container.default.hex}}

# ----------------------------
# Visual Mark (Float Calculation)
# ----------------------------
# We divide by 255.0 (float) to get the 0-1 range.
# We removed the 'round' filter to avoid syntax errors; Sioyek handles long floats fine.
visual_mark_color 0.40392157 0.39607843 0.40392157 0.2
